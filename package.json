{
	"name": "player-scout-service-core",
	"version": "3.8.0-dev.58",
	"main": "index.js",
	"scripts": {
		"dev": "nodemon",
		"prod": "nodemon -r dotenv/config . dotenv_config_path=.env.production",
		"build": "tsc && npx cpx2 \"src/locales/**/*\" \"dist/locales/\" && npx cpx2 \"src/assets/**/*\" \"dist/assets/\"",
		"clean": "rimraf dist",
		"prebuild": "npm run clean",
		"start": "node dist/index.js",
		"start:dev": "node -r dotenv/config dist/index.js dotenv_config_path=.env.development",
		"start:prod": "node -r dotenv/config dist/index.js dotenv_config_path=.env.production",
		"test": "npm-run-all cov:clean cov:unit",
		"test:all": "npm-run-all --aggregate-output cov:clean -p cov:unit cov:integration -s cov:summary-preset cov:report",
		"test:integration": "npm-run-all cov:clean cov:integration",
		"test:unit": "npm-run-all cov:clean cov:unit",
		"cov:clean": "rimraf .nyc_output && rimraf coverage",
		"cov:unit": "cross-env DOTENV_CONFIG_PATH=./.env.development jest --setupFiles dotenv/config --testTimeout=30000 --maxWorkers=50% --colors -c jest.config.unit.ts",
		"cov:integration": "cross-env DOTENV_CONFIG_PATH=./.env.test jest --setupFiles dotenv/config --testTimeout=30000 --runInBand --forceExit --colors -c jest.config.integration.ts",
		"cov:summary-preset": "mkdir .nyc_output && cp coverage/unit/coverage-final.json .nyc_output/unit.json && cp coverage/integration/coverage-final.json .nyc_output/integration.json",
		"cov:report": "nyc report --reporter html --reporter lcov --report-dir ./coverage/summary",
		"prettier-format": "prettier --config .prettierrc.json \"src/**/*.ts\" \"tests/**/*.ts\" --write",
		"prettier-check": "prettier --config .prettierrc.json \"src/**/*.ts\" \"tests/**/*.ts\" --check",
		"lint": "eslint",
		"lint:fix": "eslint --fix",
		"docker-start": "node dist/index.js",
		"migrate": "cross-env DOTENV_CONFIG_PATH=./.env.development ts-node -r dotenv/config src/migrate.ts up",
		"migrate:down": "cross-env DOTENV_CONFIG_PATH=./.env.development ts-node -r dotenv/config src/migrate.ts down",
		"migrate:status": "cross-env DOTENV_CONFIG_PATH=./.env.development ts-node -r dotenv/config src/migrate.ts pending",
		"migrate:executed": "cross-env DOTENV_CONFIG_PATH=./.env.development ts-node -r dotenv/config src/migrate.ts executed",
		"migrate:create": "ts-node src/migrate-create.ts",
		"kb:ensure-index": "cross-env DOTENV_CONFIG_PATH=./.env.development ts-node -r dotenv/config scripts/ensure-kb-vector-index.ts",
		"prepare": "husky || true",
		"postinstall": "patch-package",
		"type-check": "tsc --noEmit",
		"code-quality": "npm run type-check && npm run lint && npm run prettier-check && npm run test",
		"verify:openapi": "cross-env DOTENV_CONFIG_PATH=.env.development ts-node -r dotenv/config scripts/verify-openapi.ts",
		"compare:endpoints": "ts-node scripts/compare-endpoints.ts",
		"api:validate": "npm run verify:openapi && npm run compare:endpoints",
		"pre-commit": "npm run code-quality && npm run verify:openapi",
		"pre-push": "npm run code-quality && npm run build && npm run compare:endpoints",
		"commitlint": "commitlint --edit",
		"release": "commit-and-tag-version",
		"release:minor": "commit-and-tag-version --release-as minor",
		"release:major": "commit-and-tag-version --release-as major",
		"release:patch": "commit-and-tag-version --release-as patch"
	},
	"keywords": [],
	"author": "Livetronics",
	"license": "ISC",
	"description": "",
	"devDependencies": {
		"@commitlint/cli": "^19.8.1",
		"@commitlint/config-conventional": "^19.8.1",
		"@eslint/js": "^9.27.0",
		"@eslint/json": "^0.12.0",
		"@tsconfig/node20": "^20.1.5",
		"@types/archiver": "^6.0.4",
		"@types/cors": "^2.8.18",
		"@types/express": "^5.0.2",
		"@types/express-multipart-file-parser": "^0.1.3",
		"@types/jest": "^29.5.14",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^22.15.21",
		"@types/node-cron": "^3.0.11",
		"@types/pdf-parse": "^1.1.4",
		"@types/pdfkit": "^0.17.5",
		"@types/supertest": "^6.0.3",
		"@types/swagger-ui-express": "^4.1.8",
		"@types/validator": "^13.15.1",
		"commit-and-tag-version": "^12.7.1",
		"cpx2": "^8.0.0",
		"cross-env": "^7.0.3",
		"eslint": "^9.27.0",
		"eslint-config-prettier": "^10.1.5",
		"eslint-plugin-jest": "^28.11.0",
		"eslint-plugin-prettier": "^5.4.0",
		"globals": "^16.1.0",
		"husky": "^9.1.7",
		"jest": "^29.7.0",
		"nodemon": "^3.1.10",
		"npm-run-all": "^4.1.5",
		"nyc": "^17.1.0",
		"prettier": "3.7.4",
		"rimraf": "^6.0.1",
		"sequelize-auto": "^0.8.8",
		"sequelize-cli": "^6.6.3",
		"supertest": "^7.1.1",
		"ts-jest": "^29.3.4",
		"ts-node": "^10.9.2",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.32.1"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.80.0",
		"@aws-sdk/client-cloudwatch-logs": "^3.873.0",
		"@aws-sdk/client-s3": "^3.876.0",
		"@google/genai": "^2.10.0",
		"@octokit/auth-app": "^8.2.0",
		"@octokit/request": "^10.0.8",
		"@slack/web-api": "^7.15.2",
		"@typegoose/typegoose": "^12.16.0",
		"@types/compression": "^1.8.1",
		"@types/ioredis": "^4.28.10",
		"archiver": "^7.0.1",
		"axios": "^1.11.0",
		"compression": "^1.8.1",
		"cors": "^2.8.5",
		"dotenv": "^16.5.0",
		"exceljs": "^4.4.0",
		"express": "^5.1.0",
		"express-multipart-file-parser": "^0.1.2",
		"express-rate-limit": "^8.2.1",
		"firebase-admin": "^14.0.0",
		"form-data": "^4.0.5",
		"helmet": "^8.1.0",
		"i18next": "^25.2.1",
		"i18next-fs-backend": "^2.6.0",
		"i18next-http-middleware": "^3.7.4",
		"ioredis": "^5.9.2",
		"js-yaml": "^4.1.1",
		"mammoth": "^1.8.0",
		"moment-timezone": "^0.6.0",
		"mongodb": "~6.20.0",
		"mongoose": "^8.15.2",
		"mysql2": "^3.14.1",
		"node-cron": "^4.2.1",
		"node-sql-parser": "^5.4.0",
		"openai": "^6.33.0",
		"patch-package": "^8.0.1",
		"pdf-parse": "^1.1.1",
		"pdfkit": "^0.18.0",
		"reflect-metadata": "^0.2.2",
		"sequelize": "^6.37.7",
		"sequelize-typescript": "^2.1.6",
		"swagger-ui-express": "^5.0.1",
		"umzug": "^3.8.2",
		"undici": "^7.27.2",
		"winston": "^3.17.0",
		"winston-cloudwatch": "^6.3.0",
		"xlsx": "^0.18.5",
		"zod": "^3.25.64"
	}
}
