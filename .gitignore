dist/
build/
out/
tmp/
temp/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm/

# Optional eslint cache
.eslintcache

# dotenv environment variables file
.env.development
.env.test
.env.local
.env.production

# Mac system files
.DS_Store

# Yarn Integrity file
.yarn-integrity

# Parcel-bundler cache (https://parceljs.org/)
.cache/

