# Copy to .env and fill in.

# Port the API listens on. The frontend defaults to http://localhost:4000.
PORT=4000

# Comma-separated origins allowed to call the API.
CORS_ORIGIN=http://localhost:3000

# Anthropic API key for the explanation layer (endpoints 6 and 7).
# Leave blank to run entirely on the canned fallback reports in data/explanations.json —
# every endpoint still returns 200, so the demo works with no key at all.
ANTHROPIC_API_KEY=

# Model used for scouting reports. All facts are supplied in the prompt, so this is
# a quality/cost dial, not a correctness one.
CLAUDE_MODEL=claude-opus-4-8
